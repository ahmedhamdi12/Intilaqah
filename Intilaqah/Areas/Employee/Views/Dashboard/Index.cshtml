@{
    ViewData["Title"] = "الرئيسية";
}

<h4 class="mb-4 fw-bold">مرحباً @ViewBag.UserFullName 👋</h4>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="il-kpi">
            <h6 class="text-muted">الرصيد المتبقي للإجازات</h6>
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 text-primary">21 يوم</h3>
                <i class="ti ti-beach text-primary" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="il-kpi">
            <h6 class="text-muted">آخر راتب مودع</h6>
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 text-success">—</h3>
                <i class="ti ti-receipt text-success" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="il-kpi">
            <h6 class="text-muted">وثائق تحتاج تحديث</h6>
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 text-warning">0</h3>
                <i class="ti ti-id text-warning" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="il-kpi">
            <h6 class="text-muted">سلف قيد الطلب</h6>
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 text-secondary">0</h3>
                <i class="ti ti-coin text-secondary" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="il-card p-4">
            <div class="il-card-header">
                <h5 class="mb-0 fw-bold">آخر الإشعارات</h5>
            </div>
            <div class="text-center py-5">
                <i class="ti ti-bell-ringing text-muted mb-2" style="font-size: 3rem; opacity: 0.5;"></i>
                <h5 class="text-muted">قريباً</h5>
            </div>
        </div>
    </div>
</div>
