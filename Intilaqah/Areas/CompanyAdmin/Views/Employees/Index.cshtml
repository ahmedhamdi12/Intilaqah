@model IEnumerable<Intilaqah.Models.ViewModels.CompanyAdmin.EmployeeListItemVM>
@{
    ViewData["Title"] = "الموظفون";
}

<div class="il-page-header">
    <div>
        <h1 class="page-title">الموظفون</h1>
        <div class="page-subtitle">
            الإجمالي: @ViewBag.TotalCount |
            سعودي: @ViewBag.SaudiCount |
            نشط: @ViewBag.ActiveCount
        </div>
    </div>
    <div class="page-actions">
        <a href="/CompanyAdmin/Employees/Create" class="btn-il btn-il-primary">
            <i class="ti ti-user-plus"></i> إضافة موظف
        </a>
    </div>
</div>

<div class="il-card">
    <div class="il-card-header">
        <div style="display:flex;gap:8px;flex-wrap:wrap;flex:1">
            <input id="tableSearch" type="text" class="il-form-control"
                   placeholder="بحث بالاسم أو الرقم الوظيفي..."
                   style="max-width:260px" />
            <select id="natFilter" class="il-form-control" style="max-width:140px">
                <option value="">كل الجنسيات</option>
                <option value="Saudi">سعودي</option>
                <option value="NonSaudi">وافد</option>
            </select>
            <select id="statusFilter" class="il-form-control" style="max-width:120px">
                <option value="">كل الحالات</option>
                <option value="true">نشط</option>
                <option value="false">غير نشط</option>
            </select>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5" style="color:var(--il-muted)">
            <i class="ti ti-users" style="font-size:48px;opacity:.25"></i>
            <div class="mt-3" style="font-size:14px">لا يوجد موظفون مسجلون بعد</div>
            <a href="/CompanyAdmin/Employees/Create"
               class="btn-il btn-il-primary mt-3 d-inline-flex">
                <i class="ti ti-user-plus"></i> إضافة موظف
            </a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table class="il-table">
                <thead>
                    <tr>
                        <th>الموظف</th>
                        <th>القسم</th>
                        <th>الجنسية</th>
                        <th>الراتب الأساسي</th>
                        <th>تاريخ المباشرة</th>
                        <th>الحالة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model)
                    {
                        <tr class="emp-row"
                            data-nat="@emp.Nationality"
                            data-active="@emp.IsActive.ToString().ToLower()">
                            <td>
                                <div class="emp-cell">
                                    <div class="emp-avatar"
                                         style="background:@(emp.Nationality == Intilaqah.Models.NationalityType.Saudi ? "#0d9e6e" : "#2563a8")">
                                        @emp.FullNameAr.Substring(0, Math.Min(2, emp.FullNameAr.Length))
                                    </div>
                                    <div>
                                        <div class="emp-name">@emp.FullNameAr</div>
                                        <div class="emp-sub">
                                            @emp.EmployeeCode — @emp.JobTitle
                                            @if (emp.DocumentsExpiringSoon > 0)
                                            {
                                                <span class="il-badge danger" style="margin-right:4px">
                                                    <i class="ti ti-alert-circle"></i>
                                                    @emp.DocumentsExpiringSoon وثيقة
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>@emp.DepartmentName</td>
                            <td>
                                <span class="il-badge @(emp.Nationality == Intilaqah.Models.NationalityType.Saudi ? "active" : "info")">
                                    @(emp.Nationality == Intilaqah.Models.NationalityType.Saudi ? "سعودي" : "وافد")
                                </span>
                            </td>
                            <td>@emp.BasicSalary.ToString("N0") ر.س</td>
                            <td>@emp.HireDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="il-badge @(emp.IsActive ? "active" : "inactive")">
                                    @(emp.IsActive ? "نشط" : "غير نشط")
                                </span>
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn-il btn-il-outline btn-il-sm"
                                            type="button" data-bs-toggle="dropdown">
                                        إجراءات <i class="ti ti-chevron-down"></i>
                                    </button>
                                    <ul class="dropdown-menu"
                                        style="font-family:'Tajawal',sans-serif">
                                        <li>
                                            <a class="dropdown-item"
                                               href="/CompanyAdmin/Employees/Details/@emp.Id">
                                                <i class="ti ti-eye" style="margin-left:6px"></i>
                                                الملف الشخصي
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item"
                                               href="/CompanyAdmin/Employees/Edit/@emp.Id">
                                                <i class="ti ti-edit" style="margin-left:6px"></i>
                                                تعديل
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <form asp-action="ToggleActive"
                                                  asp-route-id="@emp.Id"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="dropdown-item @(emp.IsActive ? "text-danger" : "text-success")"
                                                        data-confirm="@(emp.IsActive ? $"هل تريد تعطيل {emp.FullNameAr}؟" : $"هل تريد تفعيل {emp.FullNameAr}؟")">
                                                    <i class="ti ti-@(emp.IsActive ? "user-off" : "user-check")"
                                                       style="margin-left:6px"></i>
                                                    @(emp.IsActive ? "تعطيل" : "تفعيل")
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
<script>
document.getElementById('natFilter')?.addEventListener('change', filterTable);
document.getElementById('statusFilter')?.addEventListener('change', filterTable);

function filterTable() {
    const nat    = document.getElementById('natFilter').value;
    const status = document.getElementById('statusFilter').value;
    const search = document.getElementById('tableSearch').value.toLowerCase();
    document.querySelectorAll('.emp-row').forEach(row => {
        const matchNat    = !nat    || row.dataset.nat    === nat;
        const matchStatus = !status || row.dataset.active === status;
        const matchSearch = !search || row.textContent.toLowerCase().includes(search);
        row.style.display = (matchNat && matchStatus && matchSearch) ? '' : 'none';
    });
}
document.getElementById('tableSearch')?.addEventListener('input', filterTable);
</script>
}
