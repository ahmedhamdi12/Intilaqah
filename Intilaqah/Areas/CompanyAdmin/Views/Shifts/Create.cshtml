@model Intilaqah.Models.ViewModels.CompanyAdmin.ShiftCreateVM
@{ ViewData["Title"] = "إضافة وردية"; }

<div class="il-page-header">
    <div><h1 class="page-title">إضافة وردية جديدة</h1></div>
    <div class="page-actions">
        <a href="/CompanyAdmin/Shifts" class="btn-il btn-il-outline">
            <i class="ti ti-arrow-right"></i> رجوع
        </a>
    </div>
</div>
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="il-card">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Name" class="il-form-label"></label>
                    <input asp-for="Name" class="il-form-control"
                           placeholder="مثال: الوردية الصباحية" />
                    <span asp-validation-for="Name"
                          class="text-danger" style="font-size:12px"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ShiftType" class="il-form-label"></label>
                    <select asp-for="ShiftType" class="il-form-control">
                        <option value="Fixed">ثابتة</option>
                        <option value="Variable">متغيرة</option>
                        <option value="Night">ليلية</option>
                        <option value="Seasonal">موسمية</option>
                    </select>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label asp-for="StartTime" class="il-form-label"></label>
                        <input asp-for="StartTime" type="time"
                               class="il-form-control" />
                        <span asp-validation-for="StartTime"
                              class="text-danger" style="font-size:12px"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="EndTime" class="il-form-label"></label>
                        <input asp-for="EndTime" type="time"
                               class="il-form-control" />
                        <span asp-validation-for="EndTime"
                              class="text-danger" style="font-size:12px"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="GraceMinutes" class="il-form-label"></label>
                    <input asp-for="GraceMinutes" type="number"
                           class="il-form-control" min="0" max="60" />
                    <div style="font-size:11.5px;color:var(--il-muted);margin-top:4px">
                        عدد الدقائق المسموح بها قبل احتساب التأخر
                    </div>
                </div>
                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="IsActive"
                               class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive"
                               class="form-check-label"
                               style="font-family:'Tajawal',sans-serif">
                            الوردية نشطة
                        </label>
                    </div>
                </div>
                <div class="d-flex gap-2 justify-content-end">
                    <a href="/CompanyAdmin/Shifts"
                       class="btn-il btn-il-outline">إلغاء</a>
                    <button type="submit" class="btn-il btn-il-primary">
                        <i class="ti ti-device-floppy"></i> حفظ الوردية
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
