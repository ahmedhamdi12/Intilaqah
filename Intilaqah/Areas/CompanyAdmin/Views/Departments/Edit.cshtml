@model Intilaqah.Models.ViewModels.CompanyAdmin.DepartmentEditVM
@{
    ViewData["Title"] = "تعديل القسم";
}

<div class="il-page-header">
    <div>
        <h1 class="page-title">تعديل: @Model.Name</h1>
    </div>
    <div class="page-actions">
        <a href="/CompanyAdmin/Departments" class="btn-il btn-il-outline">
            <i class="ti ti-arrow-right"></i> رجوع
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="il-card">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Name" class="il-form-label"></label>
                    <input asp-for="Name" class="il-form-control" />
                    <span asp-validation-for="Name"
                          class="text-danger" style="font-size:12px"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ManagerId" class="il-form-label"></label>
                    <select asp-for="ManagerId"
                            asp-items="Model.Managers"
                            class="il-form-control">
                        <option value="">-- بدون مدير --</option>
                    </select>
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="IsActive"
                               class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive"
                               class="form-check-label"
                               style="font-family:'Tajawal',sans-serif">
                            القسم نشط
                        </label>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a href="/CompanyAdmin/Departments"
                       class="btn-il btn-il-outline">إلغاء</a>
                    <button type="submit" class="btn-il btn-il-primary">
                        <i class="ti ti-device-floppy"></i> حفظ التعديلات
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}
