@model IEnumerable<Intilaqah.Models.ViewModels.CompanyAdmin.DepartmentListItemVM>
@{
    ViewData["Title"] = "الأقسام";
}

<div class="il-page-header">
    <div>
        <h1 class="page-title">الأقسام</h1>
        <div class="page-subtitle">
            الإجمالي: @ViewBag.TotalCount |
            نشط: @ViewBag.ActiveCount
        </div>
    </div>
    <div class="page-actions">
        <a href="/CompanyAdmin/Departments/Create" class="btn-il btn-il-primary">
            <i class="ti ti-building-plus"></i> إضافة قسم
        </a>
    </div>
</div>

<div class="il-card">
    @if (!Model.Any())
    {
        <div class="text-center py-5" style="color:var(--il-muted)">
            <i class="ti ti-building" style="font-size:48px;opacity:.25"></i>
            <div class="mt-3" style="font-size:14px">لا توجد أقسام مسجلة بعد</div>
            <a href="/CompanyAdmin/Departments/Create"
               class="btn-il btn-il-primary mt-3 d-inline-flex">
                <i class="ti ti-building-plus"></i> إضافة قسم
            </a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table class="il-table">
                <thead>
                    <tr>
                        <th>القسم</th>
                        <th>المدير</th>
                        <th>عدد الموظفين</th>
                        <th>الحالة</th>
                        <th>تاريخ الإنشاء</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dept in Model)
                    {
                        <tr>
                            <td><strong>@dept.Name</strong></td>
                            <td>@dept.ManagerName</td>
                            <td>
                                @if (dept.EmployeeCount > 0)
                                {
                                    <a href="/CompanyAdmin/Departments/Employees/@dept.Id"
                                       class="il-badge info">
                                        @dept.EmployeeCount موظف
                                    </a>
                                }
                                else
                                {
                                    <span style="color:var(--il-muted);font-size:12px">
                                        لا يوجد موظفون
                                    </span>
                                }
                            </td>
                            <td>
                                <span class="il-badge @(dept.IsActive ? "active" : "inactive")">
                                    @(dept.IsActive ? "نشط" : "غير نشط")
                                </span>
                            </td>
                            <td>@dept.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="il-actions-group">
                                    <a href="/CompanyAdmin/Departments/Edit/@dept.Id" 
                                       class="il-action-btn" data-tooltip="تعديل">
                                        <i class="ti ti-edit"></i>
                                    </a>
                                    
                                    @if (dept.EmployeeCount > 0)
                                    {
                                        <a href="/CompanyAdmin/Departments/Employees/@dept.Id" 
                                           class="il-action-btn" data-tooltip="عرض الموظفين">
                                            <i class="ti ti-users"></i>
                                        </a>
                                    }
                                    
                                    <form asp-action="ToggleActive" asp-route-id="@dept.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="il-action-btn @(dept.IsActive ? "il-action-danger" : "il-action-success")" 
                                                data-tooltip="@(dept.IsActive ? "تعطيل" : "تفعيل")"
                                                data-confirm="@(dept.IsActive ? $"تعطيل قسم {dept.Name}؟" : $"تفعيل قسم {dept.Name}؟")">
                                            <i class="ti ti-@(dept.IsActive ? "toggle-left" : "toggle-right")"></i>
                                        </button>
                                    </form>

                                    @if (dept.EmployeeCount == 0)
                                    {
                                        <form asp-action="Delete" asp-route-id="@dept.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="il-action-btn il-action-danger" 
                                                    data-tooltip="حذف"
                                                    data-confirm="هل تريد حذف قسم '@dept.Name' نهائياً؟">
                                                <i class="ti ti-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
