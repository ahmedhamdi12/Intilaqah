@{
    ViewData["Title"] = "استيراد الحضور من Excel";
}

<div class="il-page-header">
    <div>
        <h1 class="page-title">استيراد الحضور</h1>
        <div class="page-subtitle">استيراد بيانات البصمة من ملف Excel</div>
    </div>
    <div class="page-actions">
        <a href="/CompanyAdmin/Attendance" class="btn-il btn-il-outline">
            <i class="ti ti-arrow-right"></i> رجوع
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">

        @* Format instructions *@
        <div class="il-card mb-3"
             style="border-right:3px solid var(--il-info);background:#eff6ff">
            <div style="font-size:13.5px;font-weight:700;margin-bottom:8px;
                        color:var(--il-info)">
                <i class="ti ti-info-circle" style="margin-left:5px"></i>
                تنسيق ملف Excel المطلوب
            </div>
            <table class="il-table" style="font-size:12.5px">
                <thead>
                    <tr>
                        <th>العمود A</th>
                        <th>العمود B</th>
                        <th>العمود C</th>
                        <th>العمود D</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>رقم الموظف</td>
                        <td>التاريخ</td>
                        <td>وقت الدخول</td>
                        <td>وقت الخروج</td>
                    </tr>
                    <tr style="color:var(--il-muted);font-size:11px">
                        <td>EMP-001</td>
                        <td>2025-05-15</td>
                        <td>08:00</td>
                        <td>17:00</td>
                    </tr>
                </tbody>
            </table>
            <div class="mt-2 text-muted" style="font-size: 11px;">
                * يجب أن يكون الصف الأول هو العناوين (سيتم تجاهله). تبدأ البيانات من الصف الثاني.
            </div>
        </div>

        <div class="il-card">
            <form id="importForm" asp-action="Import" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="mb-4 text-center p-4 border rounded" style="border-style: dashed !important; background: #fafafa;">
                    <i class="ti ti-file-spreadsheet mb-3 text-success" style="font-size: 3rem;"></i>
                    <h5 class="mb-3">اختر ملف Excel (.xlsx)</h5>
                    <input type="file" name="file" class="form-control" accept=".xlsx, .xls" required />
                </div>
                
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn-il btn-il-primary">
                        <i class="ti ti-upload"></i> استيراد البيانات
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>

<!-- Loading Overlay -->
<div id="uploadOverlay" class="il-upload-overlay">
    <div class="il-upload-card">
        <div class="il-spinner-ring">
            <div class="il-spinner-icon">
                <i class="ti ti-file-spreadsheet"></i>
            </div>
        </div>
        <div class="il-upload-title">جاري استيراد البيانات...</div>
        <div class="il-upload-subtitle">يتم معالجة ملف الحضور، يرجى الانتظار</div>
        <div class="il-upload-progress">
            <div class="il-upload-progress-bar"></div>
        </div>
        <div class="il-upload-dots">
            <span></span><span></span><span></span>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('importForm').addEventListener('submit', function (e) {
        var fileInput = this.querySelector('input[type="file"]');
        if (!fileInput.value) return;
        document.getElementById('uploadOverlay').classList.add('active');
    });
</script>
}
