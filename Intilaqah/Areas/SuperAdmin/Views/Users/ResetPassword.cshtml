@model Intilaqah.Models.ViewModels.SuperAdmin.ResetPasswordVM

@{
    ViewData["Title"] = $"تغيير كلمة مرور: {Model.UserName}";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/SuperAdmin/Users">المستخدمون</a></li>
        <li class="breadcrumb-item active" aria-current="page">تغيير كلمة المرور</li>
    </ol>
</nav>

<div class="il-page-header mb-4">
    <h3 class="mb-1 fw-bold">تغيير كلمة مرور: @Model.UserName</h3>
</div>

<div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
    <i class="ti ti-alert-triangle fs-4 me-2"></i>
    <div>
        ستُغيَّر كلمة المرور فوراً. أخبر المستخدم بكلمة المرور الجديدة.
    </div>
</div>

<div class="card border-0 shadow-sm il-card" style="max-width: 500px;">
    <div class="card-body p-4">
        <form asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserName" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label fw-bold"></label>
                <input asp-for="NewPassword" class="form-control il-form-control" type="password" dir="ltr" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-bold"></label>
                <input asp-for="ConfirmPassword" class="form-control il-form-control" type="password" dir="ltr" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger px-4">تغيير كلمة المرور</button>
                <a asp-action="Index" class="btn btn-il-outline px-4">إلغاء</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
