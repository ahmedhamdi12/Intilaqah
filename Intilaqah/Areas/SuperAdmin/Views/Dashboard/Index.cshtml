@using Intilaqah.Models
@{
    ViewData["Title"] = "لوحة تحكم المدير الأعلى";
    var expiringTenants = ViewBag.ExpiringTenants as IEnumerable<Tenant>;
    var latestTenants = ViewBag.LatestTenants as IEnumerable<Tenant>;
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="il-kpi">
            <h6 class="text-muted">الشركات النشطة</h6>
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 text-success">@ViewBag.ActiveTenantsCount</h3>
                <i class="ti ti-building text-success" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="il-kpi">
            <h6 class="text-muted">الشركات المجمدة</h6>
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 text-danger">@ViewBag.FrozenTenantsCount</h3>
                <i class="ti ti-snowflake text-danger" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="il-kpi">
            <h6 class="text-muted">عقود تنتهي قريباً</h6>
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 text-warning">@ViewBag.ExpiringContractsCount</h3>
                <i class="ti ti-alert-triangle text-warning" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="il-kpi">
            <h6 class="text-muted">عدد الباقات</h6>
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 text-primary">@ViewBag.PlansCount</h3>
                <i class="ti ti-packages text-primary" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="il-card p-4 h-100">
            <div class="il-card-header mb-3">
                <h5 class="mb-0 fw-bold">الشركات المضافة حديثاً</h5>
                <a href="/SuperAdmin/Companies" class="btn btn-sm btn-il-outline">عرض الكل</a>
            </div>
            
            @if (latestTenants != null && latestTenants.Any())
            {
                <div class="table-responsive">
                    <table class="table il-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>اسم الشركة</th>
                                <th>تاريخ الإنشاء</th>
                                <th>الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tenant in latestTenants)
                            {
                                <tr>
                                    <td class="fw-bold">@tenant.Name</td>
                                    <td>@tenant.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @{
                                            var (statusText, statusClass) = tenant.Status switch {
                                                TenantStatus.Active    => ("نشطة", "il-badge active"),
                                                TenantStatus.Frozen    => ("مجمدة", "il-badge warning"),
                                                TenantStatus.Suspended => ("موقوفة", "il-badge danger"),
                                                _                      => ("غير محدد", "il-badge inactive")
                                            };
                                        }
                                        <span class="@statusClass">@statusText</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted">لا توجد شركات مضافة حديثاً</div>
            }
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="il-card p-4 h-100">
            <div class="il-card-header mb-3">
                <h5 class="mb-0 fw-bold">عقود تنتهي قريباً</h5>
                <a href="/SuperAdmin/Companies" class="btn btn-sm btn-il-outline">عرض الكل</a>
            </div>
            
            @if (expiringTenants != null && expiringTenants.Any())
            {
                <div class="table-responsive">
                    <table class="table il-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>اسم الشركة</th>
                                <th>تاريخ الانتهاء</th>
                                <th>الأيام المتبقية</th>
                                <th>الإجراء</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tenant in expiringTenants)
                            {
                                var daysRemaining = (tenant.ContractEndDate.Date - DateTime.UtcNow.Date).Days;
                                var daysClass = daysRemaining <= 7 ? "text-danger fw-bold" : (daysRemaining <= 30 ? "text-warning fw-bold" : "");
                                
                                <tr>
                                    <td class="fw-bold">@tenant.Name</td>
                                    <td>@tenant.ContractEndDate.ToString("yyyy-MM-dd")</td>
                                    <td class="@daysClass">@daysRemaining يوم</td>
                                    <td>
                                        <a asp-controller="Companies" asp-action="Edit" asp-route-id="@tenant.Id" class="btn btn-sm btn-il-outline">تجديد</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted">لا توجد عقود تنتهي قريباً</div>
            }
        </div>
    </div>
</div>
