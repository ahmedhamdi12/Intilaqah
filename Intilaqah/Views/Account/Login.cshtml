@model Intilaqah.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول - انطلاقة HRMS</title>
    <!-- Bootstrap RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css">
    <!-- Google Fonts: Tajawal -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --il-primary: #1a3c5e;
            --il-accent: #e8a020;
            --il-bg: #f0f4f8;
            --il-surface: #ffffff;
            --il-text: #2d3748;
            --il-muted: #718096;
            --il-radius: 12px;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background-color: var(--il-bg);
            color: var(--il-text);
            min-height: 100vh;
            display: flex;
            margin: 0;
        }

        .login-container {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        .brand-panel {
            flex: 1;
            background: linear-gradient(135deg, var(--il-primary), #0d233a);
            color: white;
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .brand-panel h1 {
            font-weight: 800;
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .brand-panel p {
            font-size: 1.2rem;
            opacity: 0.9;
            margin-bottom: 2rem;
        }

        .features-list {
            list-style: none;
            padding: 0;
            text-align: right;
            font-size: 1.1rem;
        }

        .features-list li {
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .features-list i {
            color: var(--il-accent);
            font-size: 1.5rem;
        }

        .form-panel {
            flex: 1;
            background-color: var(--il-surface);
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .form-wrapper {
            width: 100%;
            max-width: 400px;
        }

        .form-wrapper h2 {
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--il-primary);
        }

        .form-wrapper p.subtitle {
            color: var(--il-muted);
            margin-bottom: 2rem;
        }

        .form-control {
            border-radius: var(--il-radius);
            padding: 0.75rem 1rem;
            border: 1px solid #e2e8f0;
        }

        .form-control:focus {
            border-color: var(--il-primary);
            box-shadow: 0 0 0 0.25rem rgba(26, 60, 94, 0.25);
        }
        
        .input-group-text {
            background: transparent;
            border-radius: var(--il-radius) 0 0 var(--il-radius);
            border-left: 1px solid #e2e8f0;
            cursor: pointer;
        }

        .btn-il-primary {
            background-color: var(--il-primary);
            color: white;
            border: none;
            border-radius: var(--il-radius);
            padding: 0.75rem;
            font-weight: 700;
            width: 100%;
            transition: all 0.3s;
        }

        .btn-il-primary:hover {
            background-color: #122a42;
            color: white;
        }

        .il-alert {
            border-radius: var(--il-radius);
            font-weight: 500;
        }

        @@media (max-width: 768px) {
            .brand-panel {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <!-- Right side form (RTL logic) -->
        <div class="form-panel">
            <div class="form-wrapper">
                <h2>أهلاً بك مجدداً</h2>
                <p class="subtitle">قم بتسجيل الدخول للوصول إلى حسابك</p>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger il-alert">
                        @TempData["Error"]
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="alert alert-danger il-alert"></div>

                <form asp-action="Login" method="post">
                    <input type="hidden" asp-for="ReturnUrl" />
                    
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold"></label>
                        <input asp-for="Email" class="form-control" placeholder="example@company.com" dir="ltr" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <input asp-for="Password" class="form-control" placeholder="••••••••" dir="ltr" id="passwordInput" />
                            <span class="input-group-text" id="togglePassword">
                                <i class="ti ti-eye"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label fw-medium"></label>
                    </div>

                    <button type="submit" class="btn btn-il-primary">
                        <i class="ti ti-login me-1"></i> تسجيل الدخول
                    </button>
                </form>
            </div>
        </div>

        <!-- Left side brand -->
        <div class="brand-panel">
            <i class="ti ti-chart-pie-3" style="font-size: 5rem; color: var(--il-accent); margin-bottom: 1rem;"></i>
            <h1>انطلاقة HRMS</h1>
            <p>النظام السحابي المتكامل لإدارة الموارد البشرية</p>
            
            <ul class="features-list">
                <li><i class="ti ti-check"></i> إدارة الموظفين والرواتب بكفاءة</li>
                <li><i class="ti ti-check"></i> تتبع الحضور والانصراف بدقة</li>
                <li><i class="ti ti-check"></i> تقارير وتحليلات فورية وشاملة</li>
                <li><i class="ti ti-check"></i> متابعة نظام نطاقات بنقرة واحدة</li>
            </ul>
        </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    
    <script>
        document.getElementById('togglePassword').addEventListener('click', function () {
            const pwd = document.getElementById('passwordInput');
            const icon = this.querySelector('i');
            if (pwd.type === 'password') {
                pwd.type = 'text';
                icon.classList.remove('ti-eye');
                icon.classList.add('ti-eye-off');
            } else {
                pwd.type = 'password';
                icon.classList.remove('ti-eye-off');
                icon.classList.add('ti-eye');
            }
        });
    </script>
</body>
</html>
