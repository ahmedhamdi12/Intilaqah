@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>غير مصرح - انطلاقة HRMS</title>
    <!-- Bootstrap RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css">
    <!-- Google Fonts: Tajawal -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --il-primary: #1a3c5e;
            --il-accent: #e8a020;
            --il-bg: #f0f4f8;
            --il-surface: #ffffff;
            --il-text: #2d3748;
            --il-muted: #718096;
            --il-radius: 12px;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background-color: var(--il-bg);
            color: var(--il-text);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
        }

        .forbidden-card {
            background: var(--il-surface);
            border-radius: var(--il-radius);
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            padding: 3rem;
            text-align: center;
            max-width: 480px;
            width: 100%;
        }

        .forbidden-icon {
            font-size: 5rem;
            color: #e53e3e;
            margin-bottom: 1rem;
        }

        .forbidden-card h1 {
            font-weight: 800;
            color: var(--il-primary);
            margin-bottom: 0.5rem;
        }

        .forbidden-card p {
            color: var(--il-muted);
            font-size: 1.1rem;
            margin-bottom: 2rem;
        }

        .btn-il-primary {
            background-color: var(--il-primary);
            color: white;
            border: none;
            border-radius: var(--il-radius);
            padding: 0.75rem 2rem;
            font-weight: 700;
            transition: all 0.3s;
            text-decoration: none;
        }

        .btn-il-primary:hover {
            background-color: #122a42;
            color: white;
        }
    </style>
</head>
<body>
    <div class="forbidden-card">
        <i class="ti ti-lock-access forbidden-icon"></i>
        <h1>غير مصرح لك</h1>
        <p>ليس لديك صلاحية للوصول إلى هذه الصفحة. تواصل مع مدير النظام إذا كنت تعتقد أن هذا خطأ.</p>
        <a href="/" class="btn btn-il-primary">
            <i class="ti ti-home me-1"></i> العودة للرئيسية
        </a>
    </div>
</body>
</html>
