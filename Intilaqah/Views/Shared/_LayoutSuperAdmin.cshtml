<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - انطلاقة HRMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/intilaqah.css" asp-append-version="true" />
    <style>
        :root {
            --il-primary: #1e1b4b;
            --il-sidebar-bg: #1e1b4b;
        }
        .il-topbar { box-shadow: 0 1px 0 #e2e8f0; }
        .il-nav-active-indicator {
            position: absolute;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 3px;
            height: 60%;
            background: #e8a020;
            border-radius: 0 4px 4px 0;
        }
        .sidebar-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: rgba(255,255,255,0.3);
            padding: 14px 20px 6px;
        }
    </style>
</head>
<body>
    <div id="sidebarOverlay" class="sidebar-overlay"></div>
    
    <header class="il-topbar px-4">
        <div class="d-flex align-items-center h-100 w-100 gap-3">
            <button id="sidebarToggle" class="btn btn-sm btn-light d-lg-none" style="border-radius:8px">
                <i class="ti ti-menu-2"></i>
            </button>
            <div class="d-flex align-items-center gap-2" style="min-width:180px">
                <div style="width:34px;height:34px;background:linear-gradient(135deg,#4f46e5,#1e1b4b);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                    <i class="ti ti-chart-pie-3" style="color:#e8a020;font-size:18px"></i>
                </div>
                <span style="font-weight:800;font-size:16px;color:#1e1b4b;letter-spacing:-0.3px">انطلاقة HRMS</span>
            </div>

            <div class="ms-auto d-flex align-items-center gap-3">
                <span style="font-size:11.5px;font-weight:600;background:#f1f5f9;color:#64748b;padding:4px 12px;border-radius:20px;">
                    <i class="ti ti-shield-check" style="color:#4f46e5"></i> مدير النظام
                </span>
                <div class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                        <div class="avatar-circle" style="background:linear-gradient(135deg,#4f46e5,#7c3aed);color:white;font-weight:700;font-size:14px">
                            <i class="ti ti-user" style="font-size:16px"></i>
                        </div>
                        <span class="d-none d-md-inline" style="font-size:13.5px;font-weight:600;color:#1e293b">@User.FindFirst("FullName")?.Value</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end border-0 mt-2" style="box-shadow:0 10px 40px rgba(0,0,0,0.12);border-radius:12px;min-width:180px;padding:8px">
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item rounded-2" style="color:#dc2626;font-size:13px;font-weight:600">
                                    <i class="ti ti-logout me-2"></i>تسجيل الخروج
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <aside class="il-sidebar">
        <div style="padding:18px 20px 14px;border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:8px">
            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,255,255,0.35);margin-bottom:2px">INTILAQAH HRMS</div>
            <div style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.85)">لوحة تحكم المنصة</div>
        </div>
        <div class="sidebar-label">الرئيسية</div>
        <ul class="nav flex-column" id="sidebarNav">
            <li class="nav-item"><a class="nav-link" href="/SuperAdmin/Dashboard"><i class="ti ti-layout-dashboard"></i>الرئيسية</a></li>
            <div class="sidebar-label">إدارة النظام</div>
            <li class="nav-item"><a class="nav-link" href="/SuperAdmin/Companies"><i class="ti ti-building"></i>الشركات</a></li>
            <li class="nav-item"><a class="nav-link" href="/SuperAdmin/Plans"><i class="ti ti-package"></i>الباقات</a></li>
            <li class="nav-item"><a class="nav-link" href="/SuperAdmin/Contracts"><i class="ti ti-file-certificate"></i>العقود</a></li>
            <li class="nav-item"><a class="nav-link" href="/SuperAdmin/Finance"><i class="ti ti-report-money"></i>المالية</a></li>
            <div class="sidebar-label">التحليلات</div>
            <li class="nav-item"><a class="nav-link" href="/SuperAdmin/Reports"><i class="ti ti-chart-bar"></i>التقارير</a></li>
            <div class="sidebar-label">الإدارة</div>
            <li class="nav-item"><a class="nav-link" href="/SuperAdmin/Users"><i class="ti ti-users"></i>المستخدمين</a></li>
            <li class="nav-item"><a class="nav-link" href="/SuperAdmin/Roles"><i class="ti ti-shield-lock"></i>الصلاحيات</a></li>
            <li class="nav-item"><a class="nav-link" href="/SuperAdmin/Settings"><i class="ti ti-settings"></i>الإعدادات</a></li>
            <li class="nav-item"><a class="nav-link" href="/SuperAdmin/Logs"><i class="ti ti-history"></i>سجل الحركات</a></li>
        </ul>
    </aside>

    <main class="il-main">
        <div class="container-fluid p-0">
            @if (TempData["Success"] != null)
            {
                <div class="il-toast alert alert-success d-flex align-items-center" role="alert">
                    <i class="ti ti-check me-2 fs-5"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="il-toast alert alert-danger d-flex align-items-center" role="alert">
                    <i class="ti ti-alert-circle me-2 fs-5"></i> @TempData["Error"]
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/intilaqah.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
